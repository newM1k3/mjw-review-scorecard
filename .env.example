# Anthropic API key — used by Netlify functions for review analysis
ANTHROPIC_API_KEY=

# --- Lead capture (netlify/functions/scorecard-lead.ts) ---
# Funnel leads are written server-side to the `scorecard_leads` collection on ImmersiveKit.
# Provide EITHER a superuser token OR superuser email+password (the function mints a token).
# If neither is set, lead capture degrades gracefully (503) and the scorecard still works.
POCKETBASE_URL=https://immersive-kit.pockethost.io
PB_SUPERUSER_TOKEN=
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=
# Optional: salt for hashing request IPs before storage
IP_HASH_SALT=
